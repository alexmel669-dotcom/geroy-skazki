# Vercel Environment Variables

# JWT Secret (минимум 32 случайных символа)
JWT_SECRET=your_jwt_secret_here_min_32_characters_long

# DeepSeek API Key
DEEPSEEK_API_KEY=sk_your_deepseek_api_key

# Yandex SpeechKit API Key
YANDEX_API_KEY=your_yandex_api_key

# Yandex Cloud Folder ID (для TTS и STT)
YANDEX_FOLDER_ID=your_yandex_folder_id

# Environment
NODE_ENV=production

# --- Локальное тестирование (скопируйте в .env.local) ---
# JWT_SECRET=dev-test-secret-minimum-32-characters-long
# NODE_ENV=development
# API-ключи DeepSeek/Yandex необязательны: включены dev-fallback в коде

# Optional: Database (для будущего использования)
# MONGODB_URI=mongodb+srv://...
# REDIS_URL=redis://...

# Optional: Email service
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_password
