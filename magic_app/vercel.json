{
  "buildCommand": "echo 'Static only'",
  "devCommand": "npm run dev",
  "github": {
    "autoDeploy": true,
    "productionBranch": "main",
    "previewBranches": ["dev", "staging"]
  },
  "version": 2,
  "functions": {
    "api/router.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/router.js" },
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/(.*\\.html)", "dest": "/public/$1" },
    { "src": "/sw.js", "dest": "/public/sw.js" },
    { "src": "/manifest.json", "dest": "/public/manifest.json" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
