{
  "name": "geroy-skazki",
  "version": "5.4.9",
  "type": "module",
  "scripts": {
    "dev": "echo 'use npx vercel dev --listen 3000'",
    "serve": "vercel dev --listen 3000",
    "start": "vercel dev --listen 3000",
    "static": "npx --yes serve public -l 3000",
    "deploy": "vercel --prod",
    "deploy:env": "powershell -ExecutionPolicy Bypass -File scripts/set-vercel-env.ps1",
    "deploy:full": "npm run deploy:env && npm run deploy",
    "lint": "echo 'No linter configured'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:syntax": "node scripts/check-syntax.mjs",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@upstash/redis": "^1.34.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vercel": "^32.7.2",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "children",
    "ai",
    "fears",
    "fairy-tales",
    "pwa"
  ],
  "author": "Lucik Team",
  "license": "UNLICENSED"
}
